        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "http://localhost:5000/api/users/forgot-password",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "users", "forgot-password"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"illusiodesigns@gmail.com\"\n}"
            },
            "event": [
              {
                "listen": "test",
                "script": {
                  "exec": [
                    "var jsonData = pm.response.json();",
                    "if (jsonData.resetToken) {",
                    "    pm.environment.set('resetToken', jsonData.resetToken);",
                    "    console.log('Reset token has been set successfully');",
                    "} else {",
                    "    console.error('No reset token found in response');",
                    "}"
                  ],
                  "type": "text/javascript"
                }
              }
            ]
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "http://localhost:5000/api/users/reset-password",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "users", "reset-password"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n    \"resetToken\": \"{{resetToken}}\",\n    \"password\": \"Illusio@123\",\n    \"confirmPassword\": \"Illusio@123\"\n}"
            }
          }
        },
